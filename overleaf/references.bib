	keywords = {Other nonmetallic inorganics},
	pages = {7555--7560},
}

@article{dumont_isotopic_1991,
	title = {Isotopic equilibration in surface reactions},
	volume = {251},
	issn = {0039-6028},
	url = {http://adsabs.harvard.edu/abs/1991SurSc.251..891D},
