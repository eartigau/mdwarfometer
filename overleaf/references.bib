	volume = {96},
	issn = {0301-0104},
	url = {http://adsabs.harvard.edu/abs/1992JChPh..96.4014D},
	doi = {10.1063/1.461851},
	abstract = {The isotopic exchange surface reaction 
A2+B2→2nAB+(1-n)A2+(1-n)B2
is investigated within (i) a model with direct dissociative adsorption
and (ii) models with one-site (or bridged) molecular adsorption
precursor states. These three kinetic schemes involve the various
associative desorption mechanisms as well as the diffusion of the
