@article{gan_tess_2022,
	title = {{TESS} discovery of a sub-{Neptune} orbiting a mid-{M} dwarf {TOI}-2136},
	url = {https://ui.adsabs.harvard.edu/abs/2022arXiv220210024G},
	abstract = {We present the discovery of TOI-2136b, a sub-Neptune planet transiting every 7.85 days a nearby M4.5V-type star, identified through photometric measurements from the TESS mission. The host star is located \$33\$ pc away with a radius of \$R\_\{{\textbackslash}ast\} = 0.34{\textbackslash}pm0.02{\textbackslash} R\_\{{\textbackslash}odot\}\$, a mass of \$0.34{\textbackslash}pm0.02{\textbackslash} M\_\{{\textbackslash}odot\}\$ and an effective temperature of \${\textbackslash}rm 3342{\textbackslash}pm100{\textbackslash} K\$. We estimate its stellar rotation period to be \$75{\textbackslash}pm5\$ days based on archival long-term photometry. We confirm and characterize the planet based on a series of ground-based multi-wavelength photometry, high-angular-resolution imaging observations, and precise radial velocities from CFHT/SPIRou. Our joint analysis reveals that the planet has a radius of \$2.19{\textbackslash}pm0.17{\textbackslash} R\_\{{\textbackslash}oplus\}\$, and a mass measurement of \$6.4{\textbackslash}pm2.4{\textbackslash} M\_\{{\textbackslash}oplus\}\$. The mass and radius of TOI2136b is consistent with a broad range of compositions, from water-ice to gas-dominated worlds. TOI-2136b falls close to the radius valley for low-mass stars predicted by the thermally driven atmospheric mass loss models, making it an interesting target for future studies of its interior structure and atmospheric properties.},
	urldate = {2022-03-21},
	journal = {arXiv e-prints},
	author = {Gan, Tianjun and Soubkiou, Abderahmane and Wang, Sharon X. and Benkhaldoun, Zouhair and Mao, Shude and Artigau, Étienne and Fouqué, Pascal and Giacalone, Steven and Theissen, Christopher A. and Aganze, Christian and Collins, Karen A. and Shporer, Avi and Barkaoui, Khalid and Ghachoui, Mourad and Howell, Steve B. and Lamman, Claire and Demangeon, Olivier D. S. and Burdanov, Artem and Cadieux, Charles and Chouqar, Jamila and Collins, Kevin I. and Cook, Neil J. and Delrez, Laetitia and Demory, Brice-Olivier and Doyon, René and Dransfield, Georgina and Dressing, Courtney D. and Ducrot, Elsa and Fan, Jiahao and Garcia, Lionel and Gill, Holden and Gillon, Michaël and Gnilka, Crystal L. and Gómez Maqueo Chew, Yilen and Günther, Maximilian N. and Henze, Christopher E. and Huang, Chelsea X. and Jehin, Emmanuel and Jensen, Eric L. N. and Lin, Zitao and McCormac, James and Murray, Catriona A. and Niraula, Prajwal and Pedersen, Peter P. and Pozuelos, Francisco J. and Queloz, Didier and Rackham, Benjamin V. and Savel, Arjun B. and Schanche, Nicole and Schwarz, Richard P. and Sebastian, Daniel and Thompson, Samantha and Timmermans, Mathilde and Triaud, Amaury H. M. J. and Vezie, Michael and Wells, Robert D. and de Wit, Julien and Ricker, George R. and Vanderspek, Roland and Latham, David W. and Seager, Sara and Winn, Joshua N. and Jenkins, Jon M.},
	month = feb,
