@article{greaves_robustness_2020,
	title = {On the {Robustness} of {Phosphine} {Signatures} in {Venus}' {Clouds}},
	url = {http://arxiv.org/abs/2012.05844},
	abstract = {We published spectra of phosphine molecules in Venus' clouds, following open-science principles in releasing data and scripts (with community input leading to ALMA re-processing, now benefiting multiple projects). Some misconceptions about de-trending of spectral baselines have also emerged, which we address here. Using the JCMT PH3-discovery data, we show that mathematically-correct polynomial fitting of periodic ripples does not lead to "fake lines" (probability {\textless} {\textasciitilde}1\%). We then show that the ripples can be characterised in a non-subjective manner via Fourier transforms. A 20 ppb PH3 feature is {\textasciitilde}5\{{\textbackslash}sigma\} compared to the JCMT baseline-uncertainty, and is distinctive as a narrow perturber of the periodic ripple pattern. The structure of the FT-derived baseline also shows that polynomial fitting, if unguided, can amplify artefacts and so artificially reduce significance of real lines.},
	urldate = {2020-12-11},
	journal = {arXiv:2012.05844 [astro-ph]},
	author = {Greaves, Jane S. and Bains, William and Petkowski, Janusz J. and Seager, Sara and Sousa-Silva, Clara and Ranjan, Sukrit and Clements, David L. and Rimmer, Paul B. and Fraser, Helen J. and Mairs, Steve and Currie, Malcolm J.},
	month = dec,
	year = {2020},
	note = {arXiv: 2012.05844},
	keywords = {Astrophysics - Earth and Planetary Astrophysics, Astrophysics - Instrumentation and Methods for Astrophysics},
}

