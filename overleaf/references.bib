	volume = {220},
	shorttitle = {{VizieR} {Online} {Data} {Catalog}},
	url = {http://adsabs.harvard.edu/abs/2013yCat..22080016M},
	abstract = {Following the works of Ford et al. (2011, Cat. J/ApJS/197/2; 
2012ApJ...756..185F) and Steffen et al. (2012ApJ...756..186S) we derived
the transit timing of 1960 Kepler objects of interest (KOIs) using the
