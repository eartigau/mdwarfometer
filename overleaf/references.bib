@article{moutou_early_2020,
	title = {Early science with {SPIRou}: near-infrared radial velocity and spectropolarimetry of the planet-hosting star {HD} 189733},
	shorttitle = {Early science with {SPIRou}},
	url = {http://arxiv.org/abs/2008.05411},
	abstract = {SPIRou is the newest spectropolarimeter and high-precision velocimeter that has recently been installed at the Canada-France-Hawaii Telescope on Maunakea, Hawaii. It operates in the near-infrared and simultaneously covers the 0.98-2.35 \{{\textbackslash}mu\}m domain at high spectral resolution. SPIRou is optimized for exoplanet search and characterization with the radial-velocity technique, and for polarization measurements in stellar lines and subsequent magnetic field studies. The host of the transiting hot Jupiter HD 189733 b has been observed during early science runs. We present the first near-infrared spectropolarimetric observations of the planet-hosting star as well as the stellar radial velocities as measured by SPIRou throughout the planetary orbit and two transit sequences. The planetary orbit and Rossiter-McLaughlin anomaly are both investigated and modeled. The orbital parameters and obliquity are all compatible with the values found in the optical. The obtained radial-velocity precision is compatible with about twice the photon-noise estimates for a K2 star under these conditions. The additional scatter around the orbit, of about 8 m/s, agrees with previous results that showed that the activity-induced scatter is the dominant factor. We analyzed the polarimetric signal, Zeeman broadening, and chromospheric activity tracers such as the 1083nm HeI and the 1282nm Pa{\textbackslash}b\{eta\} lines to investigate stellar activity. First estimates of the average unsigned magnetic flux from the Zeeman broadening of the FeI lines give a magnetic flux of 290+-58 G, and the large-scale longitudinal field shows typical values of a few Gauss. These observations illustrate the potential of SPIRou for exoplanet characterization and magnetic and stellar activity studies.},
	urldate = {2020-09-25},
	journal = {arXiv:2008.05411 [astro-ph]},
	author = {Moutou, Claire and Dalal, Shweta and Donati, Jean-Francois and Martioli, Eder and Folsom, Colin P. and Artigau, Etienne and Boisse, Isabelle and Bouchy, Francois and Carmona, Andres and Cook, Neil and Delfosse, Xavier and Doyon, Rene and Fouque, Pascal and Gaisne, Guillaume and Hebrard, Guillaume and Hobson, Melissa and Klein, Baptiste and Etangs, Alain Lecavelier des and Morin, Julien},
	month = aug,
	year = {2020},
	note = {arXiv: 2008.05411},
	keywords = {Astrophysics - Earth and Planetary Astrophysics, Astrophysics - Instrumentation and Methods for Astrophysics, Astrophysics - Solar and Stellar Astrophysics},
}

@article{martioli_spin-orbit_2020,
	title = {Spin-orbit alignment and magnetic activity in the young planetary system {AU} {Mic}},
	volume = {641},
	issn = {0004-6361, 1432-0746},
	url = {https://www.aanda.org/10.1051/0004-6361/202038695},
	doi = {10.1051/0004-6361/202038695},
	abstract = {We present high-resolution near-infrared spectropolarimetric observations using the SPIRou instrument at Canada-France-Hawaii Telescope (CFHT) during a transit of the recently detected young planet AU Mic b, with supporting spectroscopic data from iSHELL at NASA InfraRed Telescope Facility. We detect Zeeman signatures in the Stokes
              V
              profiles and measure a mean longitudinal magnetic field of ¯
              B
              
                ℓ
              
              = 46.3 ± 0.7 G. Rotationally modulated magnetic spots likely cause long-term variations of the field with a slope of d
              B
              
                ℓ
              
              /d
              t
               = −108.7 ± 7.7 G d
              −1
              . We apply the cross-correlation technique to measure line profiles and obtain radial velocities through CCF template matching. We find an empirical linear relationship between radial velocity and
              B
              
                ℓ
              
              , which allows us to estimate the radial-velocity induced by stellar activity through rotational modulation of spots for the five hours of continuous monitoring of AU Mic with SPIRou. We model the corrected radial velocities for the classical Rossiter-McLaughlin effect, using MCMC to sample the posterior distribution of the model parameters. This analysis shows that the orbit of AU Mic b is prograde and aligned with the stellar rotation axis with a sky-projected spin-orbit obliquity of
              λ
              = 0°
              −15°
              +18°
              . The aligned orbit of AU Mic b indicates that it formed in the protoplanetary disk that evolved into the current debris disk around AU Mic.},
	urldate = {2020-09-25},
	journal = {Astronomy \& Astrophysics},
	author = {Martioli, E. and Hébrard, G. and Moutou, C. and Donati, J.-F. and Artigau, É. and Cale, B. and Cook, N. J. and Dalal, S. and Delfosse, X. and Forveille, T. and Gaidos, E. and Plavchan, P. and Berberian, J. and Carmona, A. and Cloutier, R. and Doyon, R. and Fouqué, P. and Klein, B. and Lecavelier des Etangs, A. and Manset, N. and Morin, J. and Tanner, A. and Teske, J. and Wang, S.},
