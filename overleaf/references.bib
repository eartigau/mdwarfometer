@inproceedings{mundel_validation_2015,
	title = {Validation and comparison of three power prediction models for {CPV} modules},
	volume = {1679},
	url = {http://adsabs.harvard.edu/abs/2015AIPC.1679c0005M},
	doi = {10.1063/1.4931509},
	abstract = {Accurate predictive energy modelling of a solar farm requires a thorough 
understanding of solar spectral variations, along with the spectral
response and optical properties of the photovoltaic system. This paper
investigates the minimum data required to accurately predict power
output from CPV modules, comparing modelled output to both measured data
and the existing method used by Sandia PV Array Performance Model
(SAPM). Three models were derived based on various weather inputs. A
Detailed Spectral Model (DS) uses SMARTS, inputting measured air mass,
aerosols, ozone and water content, and incorporating measured DNI to
account for cloudy days. The Sub-System Algebraic Model (SSA) removes
the need for instantaneous spectrum calculations by creating equations
for each sub-cell and DNI, based on the same inputs as the DS. These two
models rely heavily on aerosol, which is not readily available.
Alternatively, an Empirical model (EMP) may be used to determine the
relationship between measured output power and easily measureable
weather data (ambient temperature, air mass, direct normal irradiance
and water content). These non-linear DS, SSA and EMP models have a bias
error of 3.09 \%, 4.24 \% and -0.67 \%, respectively. It was also found
that the SSA model can be used in lieu of the SAPM.},
	urldate = {2019-07-16},
	author = {Mundel, Hannah and Treiber, Lara and Dufour, Pascal and Coish, Nicholas and Fischer, Anton and Myrskog, Stefan},
	month = sep,
	year = {2015},
	pages = {030005},
}

@article{charretier_rapid_2015,
	title = {Rapid {Bacterial} {Identification}, {Resistance}, {Virulence} and {Type} {Profiling} using {Selected} {Reaction} {Monitoring} {Mass} {Spectrometry}},
	volume = {5},
	issn = {2045-2322},
	url = {http://adsabs.harvard.edu/abs/2015NatSR...513944C},
	doi = {10.1038/srep13944},
	abstract = {Mass spectrometry (MS) in Selected Reaction Monitoring (SRM) mode is 
proposed for in-depth characterisation of microorganisms in a
multiplexed analysis. Within 60-80 minutes, the SRM method
performs microbial identification (I), antibiotic-resistance detection
(R), virulence assessment (V) and it provides epidemiological typing
information (T). This SRM application is illustrated by the analysis of
the human pathogen Staphylococcus aureus, demonstrating its promise for
rapid characterisation of bacteria from positive blood cultures of
sepsis patients.},
	urldate = {2019-07-16},
	journal = {Scientific Reports},
	author = {Charretier, Yannick and Dauwalder, Olivier and Franceschi, Christine and Degout-Charmette, Elodie and Zambardi, Gilles and Cecchini, Tiphaine and Bardet, Chloe and Lacoux, Xavier and Dufour, Philippe and Veron, Laurent and Rostaing, Hervé and Lanet, Veronique and Fortin, Tanguy and Beaulieu, Corinne and Perrot, Nadine and Dechaume, Dominique and Pons, Sylvie and Girard, Victoria and Salvador, Arnaud and Durand, Géraldine and Mallard, Frédéric and Theretz, Alain and Broyer, Patrick and Chatellier, Sonia and Gervasi, Gaspard and van Nuenen, Marc and Ann Roitsch, Carolyn and van Belkum, Alex and Lemoine, Jérôme and Vandenesch, François and Charrier, Jean-Philippe},
	month = sep,
	year = {2015},
	pages = {13944},
}

@article{afri_state_2015,
	title = {State and parameter estimation: a nonlinear {Luenberger} observer approach},
	volume = {1511},
	shorttitle = {State and parameter estimation},
	url = {http://adsabs.harvard.edu/abs/2015arXiv151107687A},
	abstract = {The design of a nonlinear Luenberger observer for a parametrized linear 
SISO (single-input single-output) system is studied. From an
observability assumption of the system, the existence of such an
observer is concluded. In a second step, a novel algorithm for the
identification of such systems is suggested and is implemented on a
third order system. Compared to the adaptive observer available in the
litterature, it has the advantage to be of low dimension and to admit a
strict Lyapunov function. This is a long version of a paper which is
published in IEEE TAC 2017.},
	urldate = {2019-07-16},
	journal = {arXiv e-prints},
	author = {Afri, Chouaib and Andrieu, Vincent and Bako, Laurent and Dufour, Pascal},
	month = nov,
	year = {2015},
	keywords = {Mathematics - Dynamical Systems},
	pages = {arXiv:1511.07687},
}

@article{mcconnachie_detailed_2016,
	title = {The {Detailed} {Science} {Case} for the {Maunakea} {Spectroscopic} {Explorer}: the {Composition} and {Dynamics} of the {Faint} {Universe}},
	volume = {1606},
	shorttitle = {The {Detailed} {Science} {Case} for the {Maunakea} {Spectroscopic} {Explorer}},
	url = {http://adsabs.harvard.edu/abs/2016arXiv160600043M},
	abstract = {MSE is an 11.25m aperture observatory with a 1.5 square degree field of 
view that will be fully dedicated to multi-object spectroscopy. More
than 3200 fibres will feed spectrographs operating at low (R {\textasciitilde} 2000 -
3500) and moderate (R {\textasciitilde} 6000) spectral resolution, and approximately
1000 fibers will feed spectrographs operating at high (R {\textasciitilde} 40000)
resolution. MSE is designed to enable transformational science in areas
as diverse as tomographic mapping of the interstellar and intergalactic
media; the in-situ chemical tagging of thick disk and halo stars;
connecting galaxies to their large scale structure; measuring the mass
functions of cold dark matter sub-halos in galaxy and cluster-scale
hosts; reverberation mapping of supermassive black holes in quasars;
next generation cosmological surveys using redshift space distortions
and peculiar velocities. MSE is an essential follow-up facility to
current and next generations of multi-wavelength imaging surveys,
including LSST, Gaia, Euclid, WFIRST, PLATO, and the SKA, and is
designed to complement and go beyond the science goals of other planned
and current spectroscopic capabilities like VISTA/4MOST, WHT/WEAVE,
AAT/HERMES and Subaru/PFS. It is an ideal feeder facility for E-ELT, TMT
and GMT, and provides the missing link between wide field imaging and
small field precision astronomy. MSE is optimized for high throughput,
high signal-to-noise observations of the faintest sources in the
Universe with high quality calibration and stability being ensured
through the dedicated operational mode of the observatory. (abridged)},
	urldate = {2019-07-16},
	journal = {arXiv e-prints},
	author = {McConnachie, Alan and Babusiaux, Carine and Balogh, Michael and Driver, Simon and Côté, Pat and Courtois, Helene and Davies, Luke and Ferrarese, Laura and Gallagher, Sarah and Ibata, Rodrigo and Martin, Nicolas and Robotham, Aaron and Venn, Kim and Villaver, Eva and Bovy, Jo and Boselli, Alessandro and Colless, Matthew and Comparat, Johan and Denny, Kelly and Duc, Pierre-Alain and Ellison, Sara and de Grijs, Richard and Fernandez-Lorenzo, Mirian and Freeman, Ken and Guhathakurta, Raja and Hall, Patrick and Hopkins, Andrew and Hudson, Mike and Johnson, Andrew and Kaiser, Nick and Koda, Jun and Konstantopoulos, Iraklis and Koshy, George and Lee, Khee-Gan and Nusser, Adi and Pancoast, Anna and Peng, Eric and Peroux, Celine and Petitjean, Patrick and Pichon, Christophe and Poggianti, Bianca and Schmid, Carlo and Shastri, Prajval and Shen, Yue and Willot, Chris and Croom, Scott and Lallement, Rosine and Schimd, Carlo and Smith, Dan and Walker, Matthew and Willis, Jon and Colless, Alessandro Bosselli Matthew and Goswami, Aruna and Jarvis, Matt and Jullo, Eric and Kneib, Jean-Paul and Konstantopoloulous, Iraklis and Newman, Jeff and Richard, Johan and Sutaria, Firoza and Taylor, Edwar and van Waerbeke, Ludovic and Battaglia, Giuseppina and Hall, Pat and Haywood, Misha and Sakari, Charli and Schmid, Carlo and Seibert, Arnaud and Thirupathi, Sivarani and Wang, Yuting and Wang, Yiping and Babas, Ferdinand and Bauman, Steve and Caffau, Elisabetta and Laychak, Mary Beth and Crampton, David and Devost, Daniel and Flagey, Nicolas and Han, Zhanwen and Higgs, Clare and Hill, Vanessa and Ho, Kevin and Isani, Sidik and Mignot, Shan and Murowinski, Rick and Pandey, Gajendra and Salmon, Derrick and Siebert, Arnaud and Simons, Doug and Starkenburg, Else and Szeto, Kei and Tully, Brent and Vermeulen, Tom and Withington, Kanoa and Arimoto, Nobuo and Asplund, Martin and Aussel, Herve and Bannister, Michele and Bhatt, Harish and Bhargavi, SS and Blakeslee, John and Bland-Hawthorn