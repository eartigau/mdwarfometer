@article{dufour_is_2002,
	title = {Is {There} {Evidence} for {Rotation} or {Horizontal} {Motions} in {Hot} {DB} {White} {Dwarfs}?},
	volume = {575},
	issn = {0004-637X},
	url = {http://adsabs.harvard.edu/abs/2002ApJ...575.1025D},
	doi = {10.1086/341435},
	abstract = {In a recent analysis of Goddard High Resolution Spectrograph 
observations of three hot DB white dwarfs, Provencal et al. suggested
that the C II λ1335 doublet in two such objects is abnormally
broadened. This was interpreted as the signature of rotation, or perhaps
of pulsation-related horizontal motions, at a velocity of
v{\textasciitilde}60kms-1. Our reanalysis of these observations shows that a
self-consistent analysis of the observed C II profiles is possible
without calling on additional broadening mechanisms. There is thus
currently no evidence for significant rotation velocities or horizontal
motions in hot DB white dwarfs.},
	urldate = {2019-07-16},
	journal = {The Astrophysical Journal},
	author = {Dufour, P. and Wesemael, F. and Bergeron, P.},
	month = aug,
	year = {2002},
	keywords = {Stars: White Dwarfs},
	pages = {1025--1029},
}

