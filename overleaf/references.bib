should be detectable in the TESS sample.},
	urldate = {2019-07-15},
	journal = {The Astronomical Journal},
	author = {Chen, Ge and Knutson, Heather A. and Dressing, Courtney D. and Morley, Caroline V. and Werner, Michael and Gorjian, Varoujan and Beichman, Charles and Benneke, Björn and Christiansen, Jessie L. and Ciardi, David and Crossfield, Ian and Howell, Steve B. and Krick, Jessica E. and Livingston, John and Morales, Farisa Y. and Schlieder, Joshua E.},
	month = may,
	year = {2018},
	keywords = {planets and satellites: fundamental parameters, planets and satellites: individual: K2–28b, techniques: photometric},
	pages = {223},
