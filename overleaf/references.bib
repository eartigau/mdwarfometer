	title = {The {Montreal} {White} {Dwarf} {Database}: {A} {Tool} for the {Community}},
	volume = {509},
	shorttitle = {The {Montreal} {White} {Dwarf} {Database}},
	url = {http://adsabs.harvard.edu/abs/2017ASPC..509....3D},
	abstract = {We present the "Montreal White Dwarf Database (MWDD), an accessible 
database with sortable/filterable table and interactive plots that will,
when fully completed, allow the community to explore the physical
properties of all white dwarfs ever analyzed by the Montreal group, as
well as display data and analyses from the literature. We present its
