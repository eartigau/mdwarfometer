	shorttitle = {{VizieR} {Online} {Data} {Catalog}},
	url = {http://adsabs.harvard.edu/abs/2018yCat..36190152A},
	abstract = {Fig.5 shows the variation of the absorption cross-section 
σ(cm2) of the MgIHe resonance line with temperature.

