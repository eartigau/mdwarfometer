	issn = {0010-4655},
	url = {http://adsabs.harvard.edu/abs/1986CoPhC..41....1D},
	doi = {10.1016/0010-4655(86)90017-2},
	abstract = {Monte Carlo simulation of bimolecular surface reactions such as A+ 
\{1\}/\{2\}B 2→AB is presented. This technique is a powerful
tool for testing and modelling the kinetics of these reactions,
especially in the presence of inhomogeneities (clusters). We proceed by
induction starting from the simplest case (molecular adsorption) and
ending with the parallel simulation of the following elementary steps:
physisorption, molecular and dissociative chemisorption, molecular and
associative desorption and surface reactions (Langmuir-Hinshelwood
mechanism).},
