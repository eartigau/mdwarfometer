@article{dufour_raman_1995,
	title = {Raman study of {Kramers} doublets in {Nd2CuO4}},
	volume = {51},
	issn = {1098-0121},
	url = {http://adsabs.harvard.edu/abs/1995PhRvB..51.1053D},
	doi = {10.1103/PhysRevB.51.1053},
	abstract = {Raman-scattering measurements involving the Nd3+-ion crystal 
field Kramers doublets in Nd2CuO4 are reported.
The observed splitting is attributed to the lifting of the Kramers
degeneracy by the Nd-Cu exchange interaction. Below 150 K the splitting
of these crystal-field excitations is nearly temperature independent.
There are also small discontinuities in the amplitude ratio of the
doublet components at 30 and 75 K. These discontinuities can be
intepreted as arising from the direction reversal of the Nd magnetic
moment following the direction reversal of the copper exchange field at
these phase transitions.},
	urldate = {2019-07-16},
	journal = {Physical Review B},
	author = {Dufour, P. and Jandl, S. and Thomsen, C. and Cardona, M. and Wanklyn, B. M. and Changkang, C.},
