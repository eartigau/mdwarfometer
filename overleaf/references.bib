	author = {Yee, Jennifer C. and Fazio, Giovanni G. and Benjamin, Robert and Kirkpatrick, J. Davy and Malkan, Matt A. and Trilling, David and Carey, Sean and Ciardi, David R. and Apai, Daniel and Ashby, M. L. N. and Ballard, Sarah and Bean, Jacob L. and Beatty, Thomas and Berta-Thompson, Zach and Capak, P. and Charbonneau, David and Chesley, Steven and Cowan, Nicolas B. and Crossfield, Ian and Cushing, Michael C. and de Wit, Julien and Deming, Drake and Dickinson, M. and Dittmann, Jason and Dragomir, Diana and Dressing, Courtney and Emery, Joshua and Faherty, Jacqueline K. and Gagne, Jonathan and Gaudi, B. Scott and Gillon, Michael and Grillmair, Carl J. and Harris, Alan and Hora, Joseph and Ingalls, James G. and Kataria, Tiffany and Kreidberg, Laura and Krick, Jessica E. and Lowrance, Patrick J. and Mahoney, William A. and Metchev, Stanimir A. and Mommert, Michael and Migo Mueller, Michael and Shvartzvald, Yossi and Smith, Howard and Stevenson, Kevin B. and Teplitz, H. I. and Willner, S. P.},
