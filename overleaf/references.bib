@article{gagne_2mass_2018,
	title = {{2MASS} {J13243553}+6358281 {Is} an {Early} {T}-type {Planetary}-mass {Object} in the {AB} {Doradus} {Moving} {Group}},
	volume = {854},
	url = {https://ui.adsabs.harvard.edu/abs/2018ApJ...854L..27G/abstract},
	doi = {10.3847/2041-8213/aaacfd},
	abstract = {We present new radial velocity and trigonometric distance measurements indicating that the unusually red and photometrically variable T2 dwarf 2MASS J13243553+6358281 is a member of the young (̃150 Myr) AB Doradus moving group (ABDMG) based on its space velocity. We estimate its model-dependent mass in the range 11-12 M {\textless}SUB{\textgreater}Jup{\textless}/SUB{\textgreater} at the age of the ABDMG, and its trigonometric distance of 12.7 ± 1.5 pc makes it one of the nearest known isolated planetary-mass objects. The unusually red continuum of 2MASS J13243553+6358281 in the near-infrared was previously suspected to be caused by an unresolved L + T brown dwarf binary, although it was never observed with high spatial resolution imaging. This new evidence of youth suggests that a low surface gravity may be sufficient to explain this peculiar feature. Using the new parallax we find that its absolute J-band magnitude is ̃0.4 mag fainter than equivalent-type field brown dwarfs, suggesting that the binary hypothesis is unlikely. The fundamental properties of 2MASS J13243553+6358281 follow the spectral type sequence of other known high-likelihood members of the ABDMG. The effective temperature of 2MASS J13243553+6358281 provides the first precise constraint on the L/T transition at a known young age and indicates that it happens at a temperature of ̃1150 K at ̃150 Myr, compared to ̃1250 K for field brown dwarfs.},
	language = {en},
	number = {2},
	urldate = {2019-07-15},
	journal = {The Astrophysical Journal},
	author = {Gagné, Jonathan and Allers, Katelyn N. and Theissen, Christopher A. and Faherty, Jacqueline K. and Bardalez Gagliuffi, Daniella and Artigau, Étienne},
	month = feb,
	year = {2018},
	pages = {L27},
}

@article{baron_weird:_2018,
	title = {{WEIRD}: {Wide}-orbit {Exoplanet} {Search} with {InfraRed} {Direct} {Imaging}},
	volume = {156},
	shorttitle = {{WEIRD}},
	url = {https://ui.adsabs.harvard.edu/abs/2018AJ....156..137B/abstract},
	doi = {10.3847/1538-3881/aad599},
	abstract = {We report results from the Wide-orbit Exoplanet search with InfraRed Direct imaging, or WEIRD, a survey designed to search for Jupiter-like companions on very wide orbits (1000-5000 au) around young stars (\&lt;120 Myr) that are known members of moving groups in the solar neighborhood (\&lt;70 pc). Companions that share the same age, distance, and metallicity as their host while being on large enough orbits to be studied as “isolated” objects make prime targets for spectroscopic observations, and they are valuable benchmark objects for exoplanet atmosphere models. The search strategy is based on deep imaging in multiple bands across the near-infrared domain. For all 177 objects of our sample, \{z\}{\textless}SUB{\textgreater}\{ab{\textless}/SUB{\textgreater}\}{\textless}SUP{\textgreater}\{{\textbackslash}prime{\textless}/SUP{\textgreater} \}, J, [3.6], and [4.5] images were obtained with CFHT/MegaCam, GEMINI/GMOS, CFHT/WIRCam, GEMINI/Flamingos-2, and Spitzer/IRAC. Using this set of four images per target, we searched for sources with red \{z\}{\textless}SUB{\textgreater}\{ab{\textless}/SUB{\textgreater}\}{\textless}SUP{\textgreater}\{{\textbackslash}prime{\textless}/SUP{\textgreater} \} and [3.6]-[4.5] colors, typically reaching good completeness down to 2 \{M\vphantom{\{}\}{\textless}SUB{\textgreater}Jup{\textless}/SUB{\textgreater}\} companions, while going down to 1 \{M\vphantom{\{}\}{\textless}SUB{\textgreater}Jup{\textless}/SUB{\textgreater}\} for some targets, at separations of 1000-5000 au. The search yielded four candidate companions with the expected colors, but they were all rejected through follow-up proper motion observations. Our results constrain the occurrence of 1-13 \{M\vphantom{\{}\}{\textless}SUB{\textgreater}Jup{\textless}/SUB{\textgreater}\} planetary-mass companions on orbits with a semimajor axis between 1000 and 5000 au at less than 0.03, with a 95\% confidence level.},
	language = {en},
	number = {3},
	urldate = {2019-07-15},
	journal = {The Astronomical Journal},
	author = {Baron, Frédérique and Artigau, Étienne and Rameau, Julien and Lafrenière, David and Gagné, Jonathan and Malo, Lison and Albert, Loïc and Naud, Marie-Eve and Doyon, René and Janson, Markus and Delorme, Philippe and Beichman, Charles},
	month = sep,
	year = {2018},
	pages = {137},
}

@article{chene_investigating_2019-1,
	title = {Investigating the origin of the spectral line profiles of the {Hot} {Wolf}-{Rayet} {Star} {WR} 2},
	volume = {484},
	url = {https://ui.adsabs.harvard.edu/abs/2019MNRAS.484.5834C/abstract},
	doi = {10.1093/mnras/stz411},
	abstract = {The hot WN star WR 2 (HD 6327) has been claimed to have many singular characteristics. To explain its unusually rounded and relatively weak emission line profiles, it has been proposed that WR 2 is rotating close to break-up with a magnetically confined wind. Alternatively, the line profiles could be explained by the dilution of WR 2's spectrum by that of a companion. In this paper, we present a study of WR 2 using near-infrared AO imaging and optical spectroscopy and polarimetry. Our spectra reveal the presence of weak photospheric absorption lines from a B 2.5-4V companion, which however contributes only 5-10 per cent to the total light, suggesting that the companion is a background object. Therefore, its flux cannot be causing any significant dilution of the WR star's emission lines. The absence of intrinsic linear continuum polarization from WR 2 does not support the proposed fast rotation. Our Stokes V spectrum was not of sufficient quality to test the presence of a moderately strong organized magnetic field but our new modelling indicates that to confine the wind the putative magnetic field must be significantly stronger than was previously suggested sufficiently strong as to make its presence implausible.},
	language = {en},
	number = {4},
	urldate = {2019-07-15},
	journal = {Monthly Notices of the Royal Astronomical Society},
	author = {Chené, A.-N. and St-Louis, N. and Moffat, A. F. J. and Schnurr, O. and Crowther, P. A. and Wade, G. A. and Richardson, N. D. and Baranec, C. and Ziegler, C. A. and Law, N. M. and Riddle, R. and Rate, G. A. and Artigau, É and Alecian, E. and Collaboration, BinaMIcS},
	month = apr,
	year = {2019},
	pages = {5834},
}
