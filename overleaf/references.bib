@article{jura_evidence_2015,
	title = {Evidence for an {Anhydrous} {Carbonaceous} {Extrasolar} {Minor} {Planet}},
	volume = {799},
	issn = {0004-637X},
	url = {http://adsabs.harvard.edu/abs/2015ApJ...799..109J},
	doi = {10.1088/0004-637X/799/1/109},
	abstract = {Using Keck/HIRES, we report abundances of 11 different elements heavier 
than helium in the spectrum of Ton 345, a white dwarf that has accreted
one of its own minor planets. This particular extrasolar planetesimal,
which was at least 60\% as massive as Vesta, appears to have been
