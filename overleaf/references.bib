@inproceedings{handler_brite-constellation_2017,
	address = {eprint: arXiv:1611.02161},
	title = {The {BRITE}-{Constellation} {Nanosatellite} {Space} {Mission} {And} {Its} {First} {Scientific} {Results}},
	volume = {160},
	url = {http://adsabs.harvard.edu/abs/2017EPJWC.16001001H},
	doi = {10.1051/epjconf/201716001001},
	abstract = {The BRIght Target Explorer (BRITE) Constellation is the first 
nanosatellite mission applied to astrophysical research. Five satellites
in low-Earth orbits perform precise optical two-colour photometry of the
brightest stars in the night sky. BRITE is naturally well suited for
variability studies of hot stars. This contribution describes the basic
outline of the mission and some initial problems that needed to be
overcome. Some information on BRITE data products, how to access them,
and how to join their scientific exploration is provided. Finally, a
brief summary of the first scientific results obtained by BRITE is
given.},
	urldate = {2019-07-15},
	author = {Handler, G. and Pigulski, A. and Weiss, W. W. and Moffat, A. F. J. and Kuschnig, R. and Wade, G. A. and Orleański, G. and Ruciński, S. M. and Koudelka, O. and Smolec, R. and Zwintz, K. and Matthews, J. M. and Popowicz, A. and Baade, D. and Neiner, C. and Pamyatnykh, A. A. and Rowe, J. and Schwarzenberg-Czerny, A.},
	month = oct,
