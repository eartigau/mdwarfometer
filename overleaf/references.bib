}

@article{de_baere_six-_1970,
	title = {Six- and seven-body final states in {K} +p interactions at 5 {GeV}/ c},
	volume = {22},
	issn = {0550-3213},
	url = {http://adsabs.harvard.edu/abs/1970NuPhB..22..131D},
	doi = {10.1016/0550-3213(70)90217-8},
	abstract = {We present a study of six- and seven-body final states among the K 
+p interactions at 5 GeV/ c incident K + momentum.
Results on cross sections, resonance and single-particle productions are
given. Charge dependent angular correlations for pairs of pions occur as
in overlinepp and π +p interactions (the so called GGLP
effect) . In contrast, no dependence on the charge is observed in the
angular correlations between kaons and pions. The influence of the
production of K ∗ and N ∗ resonances
on these angular correlations is investigated. The predictions of a
multi-Regge Model (CŁA) are compared to the experimental results.},
	urldate = {2019-07-16},
	journal = {Nuclear Physics B},
	author = {De Baere, W. and Debaisieux, J. and De Wolf, E. and Dufour, P. and Grard, F. and Herquet, P. and Heughebaert, J. and Pape, L. and Peeters, P. and Verbeure, F. and Charrière, G. and Drijard, D. and Dunwoodie, W. M. and Eskreys, A. and Goldschmidt-Clermont, Y. and Grant, A. and Henri, V. P. and Muller, F. and Sekera, Z. and Tuominiemi, J. K.},
	month = sep,
	year = {1970},
	pages = {131--149},
}

@article{charriere_anti-lambda_1970,
	title = {Anti-lambda production in {K} +p interactions at 8.25 {GeV}/ c},
