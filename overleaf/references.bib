@article{dufour_effect_1992,
	title = {Effect of thermal segregation on surface properties and reactivity of chromium doped nickel oxide},
	volume = {269},
	issn = {0039-6028},
	url = {http://adsabs.harvard.edu/abs/1992SurSc.269.1173D},
	doi = {10.1016/0039-6028(92)91412-5},
	abstract = {Nickel-chromium oxide samples having a chromium concentration ranging 
between 0 and ˜6 at\% were prepared from coprecipitated hydroxides,
then treated for 24 h at high temperature in pure oxygen (PO2
= 1 bar) or in argon (PO2 ≈ 6×10-6 bar).
In this paper we report the results of a systematic study of the effect
of this thermal treatment on both morphology and surface properties of
these oxide microcrystals. The effects of temperature (in the
900-1470°C range) as well as of oxygen pressure and chromium content
on grain growth and surface composition and structure of these oxide
crystals were investigated by scanning electron microscopy, Auger
electron spectroscopy and X-ray photoelectron spectroscopy. The growth
of metallic nuclei in the initial stages of the oxide reduction at
340°C in hydrogen was found to be strongly inhibited by chromium and
this effect was analysed as a function of the thermal segregation of the
dopant in the surface layers of the oxide crystals.},
	urldate = {2019-07-16},
