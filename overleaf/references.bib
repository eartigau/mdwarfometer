@article{bassompierre_search_1968,
	title = {Search for baryonic resonance with {S} = +1 in {K} +p production experiments},
	volume = {27},
	issn = {0370-2693},
	url = {http://adsabs.harvard.edu/abs/1968PhLB...27..468B},
	doi = {10.1016/0370-2693(68)90243-8},
	abstract = {In about 30 000 identified events produced in K +p reactions 
at incident momenta 3.0, 3.5 and 5.0 GeV/ c we have searched for the
production of Z ∗'s. i.e. S = +1, T = 0 or 1 baryonic
resonances. No indication has been found in the examination of the
various available production reactions of Z ∗ decaying
with visible modes. Upper limits for the corresponding cross-sections
are generally less than 30 μb at 3.0 and 3.5 GeV/ c. 10 μb at 5.0
GeV/ c. Summing for a given production reaction over all possible Z
∗ decay modes. i.e. performing a missing mass type of
analysis, does not revel any further evidence.},
	urldate = {2019-07-16},
	journal = {Physics Letters B},
	author = {Bassompierre, G. and Goldschmidt-Clermont, Y. and Grant, A. and Henri, V. P. and Jennings, R. and Jongejans, B. and Linglin, D. and Muller, F. and Perreau, J. M. and Sekulin, R. and De Baere, W. and Debaisieux, J. and Dufour, P. and Grard, F. and Heughebaert, J. and Pape, L. and Peeters, P. and Verbeure, F. and Windmolders, R.},
