@inproceedings{chun_imaka:_2016,
	address = {eprint: arXiv:1608.01804},
	title = {Imaka: a ground-layer adaptive optics system on {Maunakea}},
	volume = {9909},
	shorttitle = {Imaka},
	url = {http://adsabs.harvard.edu/abs/2016SPIE.9909E..02C},
	doi = {10.1117/12.2233208},
	abstract = {We present the integration status for 'imaka, the ground-layer adaptive 
optics (GLAO) system on the University of Hawaii 2.2-meter telescope on
Maunakea, Hawaii. This wide-field GLAO pathfinder system exploits
Maunakea's highly confined ground layer and weak free-atmosphere to push
the corrected field of view to  1/3 of a degree, an areal field
approaching an order of magnitude larger than any existing or planned
GLAO system, with a FWHM   0.33" in the visible and near infrared. We
discuss the unique design aspects of the instrument, the driving science
cases and how they impact the system, and how we will demonstrate these
cases on the sky.},
