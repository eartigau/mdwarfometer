}

@article{sente_about_1994,
	title = {About the degree of dissociation of admolecules on surfaces},
	volume = {313},
	issn = {0039-6028},
	url = {http://adsabs.harvard.edu/abs/1994SurSc.313..107S},
	doi = {10.1016/0039-6028(94)91160-6},
	abstract = {The characteristics of the thermal desorption spectra obtained for 
isotopic exchange reactions have been related to the degrees of
dissociation introduced on a phenomenological basis by Matsushima [Surf.
Sci. 157 (1985) 297; 217 (1989) 155]. This formulation leads to an
underdetermined system of equations. Indispensable simplifications are
