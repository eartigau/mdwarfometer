@misc{almenara_toi-4860_2023,
	title = {{TOI}-4860 b, a short-period giant planet transiting an {M3}.5 dwarf},
	url = {https://ui.adsabs.harvard.edu/abs/2023arXiv230801454A},
	doi = {10.48550/arXiv.2308.01454},
	abstract = {We report the discovery and characterisation of a giant transiting planet orbiting around a nearby M3.5V dwarf (d = 80.4 pc, G = 15.1 mag, K=11.2 mag, R\$\_{\textbackslash}star\$ = 0.354 \${\textbackslash}pm\$ 0.011 R\$\_{\textbackslash}odot\$, M\$\_{\textbackslash}star\$ = 0.3400 \${\textbackslash}pm\$ 0.0086 M\$\_{\textbackslash}odot\$). Using the photometric time series from the Transiting Exoplanet Survey Satellite (TESS) sectors 10, 36, 46, and 63, and near-infrared spectrophotometry from ExTrA, we measured a planetary radius of 0.766 \${\textbackslash}pm\$ 0.026 R\$\_J\$ and an orbital period of 1.52 days. With high-resolution spectroscopy taken by the CFHT/SPIRou and ESO/ESPRESSO spectrographs, we refined the host star parameters ([Fe/H] = 0.27 \${\textbackslash}pm\$ 0.12) and measured the mass of the planet (0.2729 \${\textbackslash}pm\$ 0.0058 M\$\_J\$). Based on these measurements, TOI- 4860 b joins the small set of massive planets found around mid-to-late M dwarfs ({\textless} 0.4 R\$\_{\textbackslash}odot\$), providing both an interesting challenge to planet formation theory and a favourable target for further atmospheric studies with transmission spectroscopy. We identify an additional signal in the radial velocity data that we attribute to an eccentric (e = 0.657 \${\textbackslash}pm\$ 0.089) planet candidate with an orbital period of 426.9 \${\textbackslash}pm\$ 7.4 days and a minimum mass of 1.66 \${\textbackslash}pm\$ 0.26 M\$\_J\$.},
