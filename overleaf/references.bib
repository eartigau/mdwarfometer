@article{bouchy_near-infrared_2017,
	title = {Near-{InfraRed} {Planet} {Searcher} to {Join} {HARPS} on the {ESO} 3.6-metre {Telescope}},
	volume = {169},
	issn = {0722-6691},
	url = {http://adsabs.harvard.edu/abs/2017Msngr.169...21B},
	doi = {10.18727/0722-6691/5034},
	abstract = {The Near-InfraRed Planet Searcher (NIRPS) is a new ultra-stable infrared 
(YJH) spectrograph that will be installed on ESO's 3.6-metre Telescope
in La Silla, Chile. Aiming to achieve a precision of 1 m s-1,
NIRPS is designed to find rocky planets orbiting M dwarfs, and will
operate together with the High Accuracy Radial velocity Planet Searcher
(HARPS), also on the 3.6-metre Telescope. In this article we describe
the NIRPS science cases and present its main technical characteristics.},
