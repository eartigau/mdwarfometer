@article{blouin_new_2018,
	title = {A {New} {Generation} of {Cool} {White} {Dwarf} {Atmosphere} {Models}. {II}. {A} {DZ} {Star} with {Collision}-induced {Absorption}},
	volume = {867},
	issn = {0004-637X},
	url = {http://adsabs.harvard.edu/abs/2018ApJ...867..161B},
	doi = {10.3847/1538-4357/aae53a},
	abstract = {In the first paper of this series, we presented our upgraded cool white 
dwarf atmosphere code. In this second paper, we use our new models to
analyze SDSS J080440.63+223948.6 (J0804+2239), the first DZ star to show
collision-induced absorption (CIA). This object provides a crucial test
for our models, since previous versions of our code were unable to
simultaneously fit the metal absorption lines and the CIA. We find an
excellent fit to both the spectroscopic and photometric data, which
further validates the improved constitutive physics of our models. We
also show that the presence of metal lines allows lift of the degeneracy
between high and low hydrogen abundances that usually affects the fits
of white dwarfs with CIA. Finally, we investigate the potential impact
of spectroscopically undetected metals on the photometric solutions of
DC stars.},
	urldate = {2019-07-16},
	journal = {The Astrophysical Journal},
	author = {Blouin, S. and Dufour, P. and Allard, N. F. and Kilic, M.},
	month = nov,
	year = {2018},
	keywords = {stars: atmospheres, stars: individual: SDSS J080440.63+223948.6, white dwarfs},
	pages = {161},
}

